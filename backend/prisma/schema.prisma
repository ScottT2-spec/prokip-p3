generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum Grade {
  A_PLUS
  A
  B
  C
  F
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  role         Role     @default(MEMBER)
  points       Int      @default(100)
  grade        Grade    @default(A)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  pointLogs      PointLog[]      @relation("PointReceiver")
  pointsGiven    PointLog[]      @relation("PointGiver")
  tasks          Task[]          @relation("TaskAssignee")
  tasksAssigned  Task[]          @relation("TaskAssigner")
  taskActivities TaskActivity[]

  @@index([departmentId])
  @@index([grade])
  @@index([points(sort: Desc)])
  @@index([firstName, lastName])
  @@index([departmentId, grade])
  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users     User[]
  policies  Policy[]

  @@map("departments")
}

model Policy {
  id           String      @id @default(uuid())
  name         String
  description  String
  pointImpact  Int
  isGlobal     Boolean     @default(true)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  pointLogs    PointLog[]

  @@map("policies")
}

model PointLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("PointReceiver", fields: [userId], references: [id])
  givenById  String
  givenBy    User     @relation("PointGiver", fields: [givenById], references: [id])
  policyId   String?
  policy     Policy?  @relation(fields: [policyId], references: [id])
  points     Int
  reason     String
  ticketLink String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([givenById])
  @@index([createdAt(sort: Desc)])
  @@map("point_logs")
}

model RewardThreshold {
  id          String @id @default(uuid())
  grade       Grade  @unique
  minPoints   Int
  maxPoints   Int?
  title       String
  description String
  consequence String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reward_thresholds")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CLOSED
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  taskBoardId  String?    // ID from Prokip's task board for linking
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  userId       String
  user         User       @relation("TaskAssignee", fields: [userId], references: [id])
  assignedById String
  assignedBy   User       @relation("TaskAssigner", fields: [assignedById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId, status])
  @@index([status])
  @@map("tasks")
}

model TaskActivity {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  taskId       String
  taskTitle    String
  activityType String   @default("status_update") // status_update, comment, attachment, other
  createdAt    DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([taskId])
  @@map("task_activities")
}
